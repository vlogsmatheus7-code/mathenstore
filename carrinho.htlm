<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Carrinho | MathenStore</title>
    <style>
        :root { --gold: #d4af37; }
        body { background: #050505; color: white; font-family: sans-serif; padding: 20px; }
        .container { max-width: 500px; margin: 0 auto; }
        .item-cart { background: #111; padding: 15px; border-radius: 10px; margin-bottom: 10px; border: 1px solid #222; display: flex; justify-content: space-between; }
        .btn-final { display: block; width: 100%; padding: 18px; background: #25d366; color: white; text-align: center; border-radius: 30px; text-decoration: none; font-weight: bold; margin-top: 20px; }
        select { width: 100%; padding: 12px; background: #222; color: white; border: 1px solid var(--gold); border-radius: 8px; margin-top: 10px; }
    </style>
</head>
<body>
    <div class="container">
        <h2>🛒 Meu Carrinho</h2>
        <div id="lista"></div>
        <h3 id="total" style="text-align:right; color:var(--gold)"></h3>
        <div style="background:#111; padding:15px; border-radius:10px; border:1px solid #222">
            <label>Forma de Pagamento:</label>
            <select id="pag"><option>PIX</option><option>Cartão de Crédito</option><option>iPhone + Volta</option></select>
        </div>
        <a href="#" onclick="enviar()" class="btn-final">Finalizar no WhatsApp</a>
        <button onclick="localStorage.removeItem('cart'); location.reload();" style="background:none; border:none; color:red; width:100%; margin-top:20px; cursor:pointer">Limpar Carrinho</button>
        <a href="index.html" style="display:block; text-align:center; color:var(--gold); margin-top:20px; text-decoration:none">← Voltar</a>
    </div>
    <script>
        const cart = JSON.parse(localStorage.getItem('cart')) || [];
        const lista = document.getElementById('lista');
        let total = 0;
        cart.forEach(i => {
            lista.innerHTML += `<div class="item-cart"><span>${i.nome} (${i.gb})</span><span>R$ ${i.preco}</span></div>`;
            total += parseFloat(i.preco.replace('.','').replace(',','.'));
        });
        document.getElementById('total').innerText = 'Total: R$ ' + total.toLocaleString('pt-BR');

        function enviar() {
            if(cart.length === 0) return;
            const pag = document.getElementById('pag').value;
            let msg = '*Novo Pedido MathenStore*%0A%0A';
            cart.forEach(i => msg += `- ${i.nome} (${i.gb})%0A`);
            msg += `%0A*Pagamento:* ${pag}`;
            window.location.href = `https://wa.me/5581985666394?text=${msg}`;
        }
    </script>
</body>
</html>
